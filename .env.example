# Example environment variables for backend-B
# Copy to .env locally and fill in real values (DO NOT commit .env)

PORT=5000
MONGODB_URI=YOUR_MONGODB_URI_HERE   # e.g. mongodb+srv://user:password@cluster.mongodb.net/dbname
PUBLIC_BASE_URL=https://backend-b-production-b8ac.up.railway.app
JWT_SECRET=your_jwt_secret_here
ALLOWED_ORIGINS=https://bijnoormain.vercel.app,https://your-admin-url.example

# Optional: other provider-specific vars
# RAILWAY_STATIC_URL=... (only set in Railway UI)
